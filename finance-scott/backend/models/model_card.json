{
  "name": "Income Transaction Classifier",
  "description": "Classifies financial transaction descriptions as income or non-income",
  "models": {
    "tfidf_logreg": {
      "file": "tfidf_pipeline.pkl",
      "type": "sklearn",
      "use_case": "Fast inference, no GPU needed"
    },
    "distilbert": {
      "path": "./best_model",
      "type": "transformers",
      "use_case": "High accuracy, needs GPU for fast inference"
    }
  },
  "input": "Transaction description string",
  "output": "probability (0-1) that the transaction is income",
  "threshold": 0.5,
  "training_data": {
    "total_samples": 225317,
    "income_samples": 122384,
    "non_income_samples": 102933
  },
  "usage_example": {
    "python": "predict_income_bert('Salary January TCS')",
    "returns": "(description, probability, is_income_bool)"
  }
}